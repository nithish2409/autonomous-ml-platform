# Database Settings
# For local dev without Docker, use localhost:5432. For Docker, postgres:5432
DATABASE_URL=postgresql+asyncpg://ml_user:ml_password@localhost:5432/ml_platform

# MinIO / Object Storage Settings
# For local dev without Docker, use localhost:9000. For Docker, minio:9000
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=ml-artifacts

# Ollama / LLM Settings
# For local dev without Docker, use localhost:11434. For Docker, http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest
