### A.3 Training Runner — Optuna Hyperparameter Optimization

```python
# training_runner.py — Bayesian HPO with model-specific search spaces

def _run_hyperparameter_search(self, X_train, y_train, model_class: str,
                                 n_trials: int = 10):
    """Bayesian hyperparameter optimization using Optuna."""
    
    def objective(trial):
        if model_class == "RandomForestClassifier":
            params = {
                "n_estimators": trial.suggest_int("n_estimators", 50, 300),
                "max_depth": trial.suggest_int("max_depth", 3, 20),
            }
            model = RandomForestClassifier(**params, random_state=42)
        elif model_class == "XGBClassifier":
            params = {
                "learning_rate": trial.suggest_float("learning_rate", 0.01, 0.3),
                "max_depth": trial.suggest_int("max_depth", 3, 10),
            }
            model = XGBClassifier(**params, random_state=42,
                                   use_label_encoder=False, eval_metric="mlogloss")
        elif model_class == "LogisticRegression":
            params = {
                "C": trial.suggest_float("C", 0.01, 10.0, log=True),
            }
            model = LogisticRegression(**params, max_iter=1000, random_state=42)
        
        # 3-fold cross-validation with F1-weighted scoring
        scores = cross_val_score(model, X_train, y_train, cv=3,
                                  scoring="f1_weighted")
        return scores.mean()
    
    study = optuna.create_study(direction="maximize")
    study.optimize(objective, n_trials=n_trials)
    return study.best_params, study.best_value
```

