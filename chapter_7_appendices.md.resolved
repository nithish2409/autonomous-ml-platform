### A.5 Policy Evaluator — Guardrails Enforcement

```python
# policy_evaluator.py — Policy validation for autonomous decisions

async def evaluate_policies(self, decision: dict, model_id: str,
                              db: AsyncSession) -> dict:
    """Evaluate decision against all active policy rules."""
    
    policies = await self._get_active_policies(db)
    violations = []
    
    for policy in policies:
        if policy.policy_type == "freeze_window":
            if self._is_in_freeze_window(policy.config):
                violations.append("Deployment freeze window active")
        
        elif policy.policy_type == "gpu_limit":
            max_gpu = policy.config.get("max_gpu_per_job", 8)
            if decision.get("gpu_requested", 0) > max_gpu:
                violations.append(f"GPU request exceeds limit ({max_gpu})")
        
        elif policy.policy_type == "daily_cost_cap":
            max_cost = policy.config.get("max_daily_cost", 500)
            if decision.get("projected_cost", 0) > max_cost:
                violations.append(f"Projected cost exceeds cap (${max_cost})")
        
        elif policy.policy_type == "retrain_rate_limit":
            max_retrains = policy.config.get("max_per_24h", 50)
            recent_count = await self._count_recent_retrains(model_id, db)
            if recent_count >= max_retrains:
                violations.append(f"Rate limit reached ({max_retrains}/24h)")
    
    return {
        "approved": len(violations) == 0,
        "violations": violations
    }
```

