### A.2 LLM Decision Engine — Structured Prompt and Response Validation

```python
# llm_decision_engine.py — LLM prompt construction and validation

def _build_prompt(self, context: dict) -> str:
    """Build structured prompt for LLM decision-making."""
    prompt = f"""You are an ML Operations decision engine. Analyze the following 
monitoring data and respond with a JSON object containing 'analysis' 
(your reasoning) and 'strategy' (either 'RETRAIN' or 'ALERT').

Current Model: {context['model_name']} v{context['version']}
Framework: {context['framework']}
Drift Score: {context['drift_score']:.4f}
Performance Delta: {context['performance_delta']:.4f}
Severity: {context['severity']}
Request Count: {context['request_count']}
Average Latency: {context['avg_latency']:.2f}ms

Rules:
- Only respond with valid JSON
- strategy must be exactly 'RETRAIN' or 'ALERT'
- If uncertain, choose 'ALERT'

Respond ONLY with the JSON object, no markdown or commentary."""
    return prompt


def _validate_response(self, response: dict) -> bool:
    """Validate LLM response against expected schema."""
    required_keys = {"analysis", "strategy"}
    if not required_keys.issubset(response.keys()):
        return False
    if response["strategy"] not in ["RETRAIN", "ALERT"]:
        return False
    return True
```

