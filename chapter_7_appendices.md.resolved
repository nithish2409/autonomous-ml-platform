### A.6 Automation Executor — Drift Classification and Strategy Mapping

```python
# automation_executor.py — Drift analysis and strategy selection

def _classify_drift(self, drift_score: float, feature_drifts: dict) -> str:
    """Classify drift type based on score and feature distribution."""
    if drift_score < 0.1:
        return "no_drift"
    
    high_drift_features = [f for f, d in feature_drifts.items() if d > 0.3]
    total_features = len(feature_drifts)
    
    if len(high_drift_features) > total_features * 0.5:
        return "concept_drift"   # Widespread → full retraining
    else:
        return "feature_drift"   # Isolated → targeted tuning


# Strategy mapping
STRATEGY_MAP = {
    "concept_drift": "full_search",    # Full HPO with all enhancements
    "feature_drift": "quick_tune",     # Targeted hyperparameter tuning
    "no_drift":      "incremental",    # Minimal retraining with defaults
}
```

