### A.4 Model Evaluator — Candidate vs. Production Comparison

```python
# model_evaluator.py — Model evaluation and promotion decision

async def evaluate_candidate(self, candidate_metrics: dict,
                               production_metrics: dict,
                               task_type: str = "classification") -> dict:
    """Compare candidate model against production baseline."""
    
    if not production_metrics:
        # First real training — auto-promote
        return {"promoted": True, "reason": "No existing baseline"}
    
    if task_type == "classification":
        accuracy_delta = (candidate_metrics.get("accuracy", 0) -
                         production_metrics.get("accuracy", 0))
        f1_delta = (candidate_metrics.get("f1_score", 0) -
                   production_metrics.get("f1_score", 0))
        
        improvement_threshold = 0.01  # 1% minimum improvement
        promoted = accuracy_delta >= improvement_threshold
        
        return {
            "promoted": promoted,
            "accuracy_delta": accuracy_delta,
            "f1_delta": f1_delta,
            "threshold": improvement_threshold,
            "reason": "Meets threshold" if promoted else "Below threshold"
        }
    
    elif task_type == "regression":
        r2_delta = (candidate_metrics.get("r2_score", 0) -
                   production_metrics.get("r2_score", 0))
        mse_delta = (production_metrics.get("mse", 0) -
                    candidate_metrics.get("mse", 0))  # Lower MSE is better
        
        promoted = r2_delta >= 0.01
        return {
            "promoted": promoted,
            "r2_delta": r2_delta,
            "mse_delta": mse_delta,
        }
```

