## Appendix A: Source Code

### A.1 Drift Monitoring — Mean-Shift Computation

```python
# monitoring_service.py — Drift Score Computation

async def compute_drift(self, model_id: str, db: AsyncSession):
    """Compute statistical drift for a model against baseline."""
    
    # Get baseline statistics from dataset
    dataset = await self._get_dataset(model_id, db)
    baseline_stats = dataset.baseline_stats  # JSONB: {feature: {mean, std, missing}}
    
    # Get recent inference logs (rolling window of 100)
    recent_logs = await self._get_recent_logs(model_id, db, limit=100)
    
    if not recent_logs:
        return {"drift_score": 0.0, "feature_drifts": {}}
    
    # Build DataFrame from inference logs
    df = pd.DataFrame([log.input_features for log in recent_logs])
    
    feature_drifts = {}
    for feature, stats in baseline_stats.items():
        if feature in df.columns and stats.get("std", 0) > 0:
            current_mean = df[feature].mean()
            # Normalized mean-shift drift formula
            raw_drift = abs(current_mean - stats["mean"]) / stats["std"]
            normalized_drift = min(raw_drift / 3.0, 1.0)
            feature_drifts[feature] = normalized_drift
    
    # Global drift score (average of all feature drifts)
    if feature_drifts:
        global_drift = sum(feature_drifts.values()) / len(feature_drifts)
    else:
        global_drift = 0.0
    
    return {
        "drift_score": global_drift,
        "feature_drifts": feature_drifts
    }
```

